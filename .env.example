# Cerebro — 群体智能协同引擎 配置模板
# 复制此文件为 .env 并填写实际值

# Discord Bot Token (必填)
# 从 Discord Developer Portal -> Bot 页面获取
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Factory API Key (可选，如已配置在环境变量中则不需要)
# FACTORY_API_KEY=fk-your-api-key-here

# 默认 AI 模型 (可选)
DEFAULT_MODEL=custom:MiniMax-M2.7

# Droid transport (可选，默认 cli；sdk 为后续阶段预留)
DROID_TRANSPORT=cli

# 工作区目录 (可选，默认 ./droid_workspaces)
# 用于存放临时工作区和 repo 克隆
WORKSPACES_DIR=./droid_workspaces

# 并发控制 (可选，默认 2)
MAX_CONCURRENT_TASKS=2

# ============================================================================
# 使用说明
# ============================================================================
# 
# /task 命令支持以下格式：
# 
#   /task <描述>                        # 纯问答，不需要文件操作
#   /task <描述> repo:D:/Projects/MyApp # 指定 Git 仓库
#   /task <描述> workspace:D:/tmp/work  # 指定工作目录
# 
# 示例：
#   /task 解释什么是装饰器
#   /task 重构 login 模块 repo:D:/Projects/MyApp
#   /task 写个备份脚本 workspace:D:/scripts
# 

