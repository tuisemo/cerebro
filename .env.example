# Factory Droid x Discord 智能协同引擎 配置模板
# 复制此文件为 .env 并填写实际值

# Discord Bot Token (必填)
# 从 Discord Developer Portal -> Bot 页面获取
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Factory API Key (可选，如已配置在环境变量中则不需要)
# FACTORY_API_KEY=fk-your-api-key-here

# 基础仓库路径 (必填，用于创建工作区沙盒)
# Windows 绝对路径，使用正斜杠或双反斜杠
BASE_REPO_PATH=D:/Projects/YourTargetRepository

# 默认 AI 模型 (可选，默认 claude-3-5-sonnet-20241022)
# 支持自定义模型名称
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# 并发控制 (可选，默认 2)
# MAX_CONCURRENT_TASKS=2

# 工作区目录 (可选，默认 ./droid_workspaces)
# WORKSPACES_DIR=./droid_workspaces
